# ──────────────────────────────────────────────────
#  AandolanBot — Environment Variables
# ──────────────────────────────────────────────────
#
# SETUP INSTRUCTIONS:
#  1. Copy this file to .env.local:
#       cp .env.local.example .env.local
#  2. Fill in the value below with your actual API endpoint.
#  3. Restart the dev server: pnpm dev
#
# ──────────────────────────────────────────────────

# The full URL of your chatbot backend endpoint.
# The frontend will POST to this URL with body: { "question": "..." }
# The backend must respond with:          { "markdown": "..." }
#
# Example:
#   NEXT_PUBLIC_API_URL=https://api.example.com/v1/query
#   NEXT_PUBLIC_API_URL=http://localhost:8000/ask
NEXT_PUBLIC_API_URL=
